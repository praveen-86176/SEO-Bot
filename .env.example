# Application Environment (development, production, test)
NODE_ENV=development
# Port number for the server
PORT=3000
# PostgreSQL connection URL
DATABASE_URL=postgresql://user:password@localhost:5432/seo_bot?schema=public
# Redis connection URL
REDIS_URL=redis://localhost:6379
# BullMQ queue name for SEO analysis
BULL_QUEUE_NAME=seo-analysis
# CORS origin (comma-separated list for multiple)
CORS_ORIGIN=http://localhost:3000
# SerpAPI key for search results
SERP_API_KEY=your_serpapi_key_here
# Anthropic API key for AI analysis
ANTHROPIC_API_KEY=your_anthropic_api_key_here
